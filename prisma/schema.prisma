datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Inquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  type      String
  subject   String
  message   String
  createdAt DateTime @default(now())
  status    String   @default("unread") // unread, reviewed, archived
}
